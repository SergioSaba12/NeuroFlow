NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend email notifications for waitlist submissions.
# Create an API key at https://resend.com/api-keys
RESEND_API_KEY=

# Where new waitlist signups should be sent.
WAITLIST_TO_EMAIL=you@example.com

# Optional. Without a verified domain, Resend's onboarding sender is only suitable for testing.
RESEND_FROM_EMAIL=NeuroFlow <onboarding@resend.dev>
